#==============================================================================
# ModaPusula — Ortam Değişkenleri
# Kopyalama: cp .env.example .env && php artisan key:generate
# Üretimde gerçek domain, veritabanı ve e-posta değerlerini girin.
# Sahte domain veya parola bu dosyaya yazılmaz.
#==============================================================================

APP_NAME=ModaPusula
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://ornek-domaininiz.com
APP_TIMEZONE=Europe/Istanbul

APP_LOCALE=tr
APP_FALLBACK_LOCALE=tr
APP_FAKER_LOCALE=tr_TR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

#------------------------------------------------------------------------------
# Günlük kayıtları
#------------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

#------------------------------------------------------------------------------
# Veritabanı (Coolify MySQL servisi veya harici sunucu)
#------------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=modapusula
DB_USERNAME=modapusula
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

#------------------------------------------------------------------------------
# Oturum ve önbellek
#------------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

CACHE_STORE=database

#------------------------------------------------------------------------------
# Kuyruk ve dosya sistemi
#------------------------------------------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

#------------------------------------------------------------------------------
# E-posta (üretimde SMTP bilgilerini doldurun; boş bırakılabilir)
#------------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

#------------------------------------------------------------------------------
# Vite / frontend
#------------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"

#------------------------------------------------------------------------------
# AdSense ve gizlilik (birincil kaynak: /admin/adsense paneli)
# Aşağıdaki değişkenler yalnızca referans içindir; canlı ayarlar veritabanında
# site_settings tablosunda tutulur. Deploy sonrası admin panelinden yönetin.
#------------------------------------------------------------------------------
# Doğrulama meta etiketi (onay öncesi açılabilir)
# ADSENSE_VERIFICATION_ENABLED=false
# ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
# Reklam kutuları (onay + CMP sonrası açılmalı)
# ADSENSE_ADS_ENABLED=false
# ADSENSE_AUTO_ADS_ENABLED=false
# ADSENSE_PUBLISHER_ID=pub-XXXXXXXXXXXXXXXX
# ADSENSE_ARTICLE_MIDDLE_SLOT=
# ADSENSE_ARTICLE_BOTTOM_SLOT=
# Google sertifikalı CMP yapılandırıldı (manuel onay)
# CERTIFIED_CMP_CONFIGURED=false

#------------------------------------------------------------------------------
# Deploy / Docker (Coolify)
#------------------------------------------------------------------------------
# Kontrollü migration: deploy sonrası elle çalıştırın (docs/deployment.md)
# RUN_MIGRATIONS=false
# İlk deploy'da storage:link start script içinde çalışır
