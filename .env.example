#==============================================================================
# ModaPusula — Ortam Değişkenleri
#
# Kurulum:
#   cp .env.example .env
#   php artisan key:generate
#   touch database/database.sqlite
#   php artisan migrate --seed
#
# Üretimde gerçek domain ve yasal iletişim değerlerini girin.
# Sahte domain veya parola bu dosyaya yazılmaz.
#==============================================================================

APP_NAME=ModaPusula
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://ornek-domaininiz.com
APP_TIMEZONE=Europe/Istanbul

APP_LOCALE=tr
APP_FALLBACK_LOCALE=tr
APP_FAKER_LOCALE=tr_TR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

#------------------------------------------------------------------------------
# Yerel geliştirme (üretimde kullanmayın)
#------------------------------------------------------------------------------
# APP_ENV=local
# APP_DEBUG=true
# APP_URL=http://127.0.0.1:8000
# LOG_LEVEL=debug
# SESSION_SECURE_COOKIE=false
# MAIL_MAILER=log

#------------------------------------------------------------------------------
# Günlük kayıtları
#------------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

#------------------------------------------------------------------------------
# Veritabanı (SQLite — MySQL kullanılmaz)
#------------------------------------------------------------------------------
DB_CONNECTION=sqlite
# DB_DATABASE=
# Boş bırakılırsa: database/database.sqlite
# Coolify: /var/www/html/database volume bağlayın (docs/deployment.md)

#------------------------------------------------------------------------------
# Oturum ve önbellek
#------------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

CACHE_STORE=database

#------------------------------------------------------------------------------
# Kuyruk ve dosya sistemi
#------------------------------------------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

#------------------------------------------------------------------------------
# E-posta (üretimde SMTP; yerelde MAIL_MAILER=log yeterli)
#------------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

#------------------------------------------------------------------------------
# Vite / frontend
#------------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"

#------------------------------------------------------------------------------
# AdSense ve gizlilik (birincil kaynak: /admin/adsense paneli)
# Canlı ayarlar veritabanında site_settings tablosunda tutulur.
#------------------------------------------------------------------------------
ADSENSE_VERIFICATION_ENABLED=true
ADSENSE_CLIENT_ID=ca-pub-4108324995084946
ADSENSE_PUBLISHER_ID=pub-4108324995084946
ADSENSE_ADS_ENABLED=false
ADSENSE_AUTO_ADS_ENABLED=false
# ADSENSE_ARTICLE_MIDDLE_SLOT=
# ADSENSE_ARTICLE_BOTTOM_SLOT=
# CERTIFIED_CMP_CONFIGURED=false

#------------------------------------------------------------------------------
# Yasal sayfa bilgileri (config/legal.php varsayılanları geçersiz kılar)
#------------------------------------------------------------------------------
# LEGAL_COMPANY_NAME="GOAT Bilişim Teknolojileri Ticaret Anonim Şirketi"
# LEGAL_CONTACT_EMAIL=modapusula@goatbilisim.com
# LEGAL_COMPANY_ADDRESS="Halkalı Merkez Mahallesi Fatih Caddesi, Serenity Plus Sitesi B Blok No: 61-63 İç Kapı No: 9, Küçükçekmece / İstanbul, Türkiye"

#------------------------------------------------------------------------------
# Deploy / Docker (Coolify)
#------------------------------------------------------------------------------
# İlk kurulumda bir kez true; sonra false
RUN_MIGRATIONS=false
# true ise demo yazıları taslak olarak yükler (otomatik yayınlamaz)
RUN_DEMO_SEED=false
# SITE_PUBLISHER_LEGAL_NAME="GOAT Bilişim Teknolojileri Ticaret A.Ş."
